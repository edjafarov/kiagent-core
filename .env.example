# Build-time OAuth client credentials — copy to .env (git-ignored) and fill
# in real values from your own Google Cloud / Microsoft Entra registrations.
# Webpack inlines these into the main-process bundle at build time; without
# them the app builds and runs, but Google/Microsoft sign-in throws a
# "this build has no … credentials" error. CI supplies them from repository
# secrets instead (see .github/workflows/kiagent-core-ci.yml).

# Google Cloud Console → APIs & Services → Credentials → OAuth client
# (type "Desktop app"). Used by the Gmail and Google Docs connectors.
GOOGLE_OAUTH_CLIENT_ID=1234567890-example.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Microsoft Entra admin center → App registrations (public client / PKCE,
# no secret). Used by the OneDrive and Microsoft 365 connectors.
MICROSOFT_OAUTH_CLIENT_ID=00000000-0000-0000-0000-000000000000
