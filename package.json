{
  "name": "electron-react-boilerplate",
  "version": "0.48.0",
  "description": "A foundation for scalable desktop apps",
  "keywords": [
    "electron",
    "boilerplate",
    "react",
    "typescript",
    "ts",
    "sass",
    "webpack",
    "hot",
    "reload"
  ],
  "homepage": "https://github.com/electron-react-boilerplate/electron-react-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/electron-react-boilerplate/electron-react-boilerplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-react-boilerplate/electron-react-boilerplate.git"
  },
  "license": "MIT",
  "author": {
    "name": "Electron React Boilerplate Maintainers",
    "email": "electronreactboilerplate@gmail.com",
    "url": "https://electron-react-boilerplate.js.org"
  },
  "contributors": [
    {
      "name": "Amila Welihinda",
      "email": "amilajack@gmail.com",
      "url": "https://github.com/amilajack"
    }
  ],
  "main": "./.erb/dll/main.bundle.dev.js",
  "workspaces": [
    "src/shared/web-ui"
  ],
  "scripts": {
    "build": "concurrently \"npm run build:main\" \"npm run build:renderer\"",
    "build:dll": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.renderer.dev.dll.ts",
    "build:main": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.main.prod.ts",
    "build:renderer": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.renderer.prod.ts",
    "postinstall": "ts-node .erb/scripts/check-native-dep.js && electron-builder install-app-deps && npm rebuild better-sqlite3 && npm run build:dll",
    "lint": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "brand:generate": "ts-node ./scripts/generate-brand-assets.ts",
    "prepackage": "node scripts/vendor-deep-extraction.mjs",
    "vendor:inference": "node ./scripts/fetch-llama-server.mjs && node ./scripts/build-vision-helper.mjs",
    "package": "ts-node ./.erb/scripts/clean.js dist && node .erb/scripts/gen-asar-unpack.js && npm run build && electron-builder build --publish never && npm run build:dll",
    "package:oss": "npm run prepackage && ts-node ./.erb/scripts/clean.js dist && node .erb/scripts/gen-asar-unpack.js && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --publish never -c.productName=kiagent-core -c.appId=org.kiagent.core -c.directories.output=release/build-oss && npm run build:dll",
    "release:build": "ts-node ./.erb/scripts/clean.js dist && node .erb/scripts/gen-asar-unpack.js && npm run build && electron-builder --publish always",
    "release": "release-it",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "prestart": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.main.dev.ts",
    "start": "ts-node ./.erb/scripts/check-port-in-use.js && npm run prestart && npm run start:renderer",
    "start:main": "concurrently -k -P \"cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --watch --config ./.erb/configs/webpack.config.main.dev.ts\" \"electronmon . -- {@}\" --",
    "start:preload": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.preload.dev.ts",
    "start:renderer": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack serve --config ./.erb/configs/webpack.config.renderer.dev.ts",
    "test": "jest",
    "test:e2e": "npm run build && playwright test --config tests/e2e/playwright.config.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "browserslist": [
    "extends browserslist-config-erb"
  ],
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ]
  },
  "jest": {
    "moduleDirectories": [
      "node_modules",
      "release/app/node_modules",
      "src"
    ],
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleNameMapper": {
      "^@main/(.*)$": "<rootDir>/src/main/$1",
      "^@renderer/(.*)$": "<rootDir>/src/renderer/$1",
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^better-sqlite3$": "<rootDir>/node_modules/better-sqlite3",
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy"
    },
    "setupFiles": [
      "./.erb/scripts/check-build-exists.ts"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "testMatch": [
      "**/?(*.)+(spec|test).[jt]s?(x)"
    ],
    "testPathIgnorePatterns": [
      "release/app/dist",
      ".erb/dll",
      "tests/e2e/",
      "<rootDir>/services/",
      "<rootDir>/.claude/worktrees/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.claude/worktrees/"
    ],
    "transform": {
      "\\.(ts|tsx)$": "ts-jest",
      "node_modules/(franc-min|trigram-utils|n-gram|collapse-white-space|jose|oidc-provider|quick-lru|nanoid|eta)/.+\\.js$": "<rootDir>/.erb/jest/esm-cjs-transformer.js",
      "\\.(js|jsx)$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(franc-min|trigram-utils|n-gram|collapse-white-space|jose|oidc-provider|quick-lru|nanoid|eta)/)"
    ]
  },
  "dependencies": {
    "@chainsafe/libp2p-yamux": "^7.0.4",
    "@electron/notarize": "^3.0.0",
    "@hyzyla/pdfium": "^2.1.13",
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "acme-client": "^5.4.0",
    "chokidar": "^3.6.0",
    "csv-parse": "^6.2.1",
    "electron-debug": "^4.1.0",
    "electron-log": "^5.3.2",
    "electron-updater": "^6.8.9",
    "email-reply-parser": "^1.9.4",
    "fast-glob": "^3.3.3",
    "franc-min": "^6.2.0",
    "google-auth-library": "^10.6.2",
    "jose": "^6.2.3",
    "mammoth": "^1.12.0",
    "mime": "^3.0.0",
    "oidc-provider": "^9.8.3",
    "pdf-parse": "^1.1.1",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.1.0",
    "semver": "^7.8.5",
    "snowball-stemmers": "^0.6.0",
    "tar": "^7.5.19",
    "turndown": "^7.2.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.60.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "@sinonjs/fake-timers": "^15.4.0",
    "@svgr/webpack": "^8.1.0",
    "@teamsupercell/typings-for-css-modules-loader": "^2.5.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.14",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.13.10",
    "@types/node-forge": "^1.3.14",
    "@types/pdf-parse": "^1.1.5",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "@types/react-test-renderer": "^19.0.0",
    "@types/semver": "^7.7.1",
    "@types/sinonjs__fake-timers": "^15.0.1",
    "@types/turndown": "^5.0.6",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "adm-zip": "^0.5.18",
    "better-sqlite3": "^12.11.1",
    "browserslist-config-erb": "^0.0.3",
    "chalk": "^4.1.2",
    "concurrently": "^9.1.2",
    "core-js": "^3.41.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "detect-port": "^2.1.0",
    "dotenv": "^16.6.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-devtools-installer": "^4.0.0",
    "electronmon": "^2.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-erb": "^4.1.0",
    "eslint-import-resolver-typescript": "^4.1.1",
    "eslint-import-resolver-webpack": "^0.13.10",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.2",
    "nock": "^14.0.15",
    "png-to-ico": "^2.1.8",
    "prettier": "^3.5.3",
    "react-refresh": "^0.16.0",
    "react-test-renderer": "^19.0.0",
    "release-it": "^19.2.4",
    "rimraf": "^6.0.1",
    "sass": "^1.86.0",
    "sass-loader": "^16.0.5",
    "sharp": "^0.34.5",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "tmp-promise": "^3.0.3",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^3.15.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.8.2",
    "url-loader": "^4.1.1",
    "webpack": "^5.98.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge": "^6.0.1"
  },
  "build": {
    "productName": "KIAgent",
    "appId": "de.lokalkiagent.KIAgent",
    "asar": true,
    "afterSign": ".erb/scripts/notarize.js",
    "asarUnpack": [
      "**/*.{node,dll}",
      "**/@chainsafe/is-ip/**",
      "**/@chainsafe/libp2p-yamux/**",
      "**/@chainsafe/netmask/**",
      "**/@dnsquery/dns-packet/**",
      "**/@leichtgewicht/ip-codec/**",
      "**/@libp2p/crypto/**",
      "**/@libp2p/interface/**",
      "**/@libp2p/logger/**",
      "**/@libp2p/utils/**",
      "**/@multiformats/dns/**",
      "**/@multiformats/multiaddr/**",
      "**/@noble/curves/**",
      "**/@noble/hashes/**",
      "**/@sindresorhus/fnv1a/**",
      "**/abort-error/**",
      "**/any-signal/**",
      "**/delay/**",
      "**/eventemitter3/**",
      "**/get-iterator/**",
      "**/hashlru/**",
      "**/interface-datastore/**",
      "**/interface-store/**",
      "**/is-loopback-addr/**",
      "**/is-plain-obj/**",
      "**/it-foreach/**",
      "**/it-merge/**",
      "**/it-peekable/**",
      "**/it-pipe/**",
      "**/it-pushable/**",
      "**/it-queueless-pushable/**",
      "**/it-stream-types/**",
      "**/main-event/**",
      "**/ms/**",
      "**/multiformats/**",
      "**/netmask/**",
      "**/p-defer/**",
      "**/p-queue/**",
      "**/p-timeout/**",
      "**/progress-events/**",
      "**/protons-runtime/**",
      "**/race-event/**",
      "**/race-signal/**",
      "**/supports-color/**",
      "**/uint8-varint/**",
      "**/uint8arraylist/**",
      "**/uint8arrays/**",
      "**/utf8-codec/**",
      "**/weald/**"
    ],
    "files": [
      "dist",
      "node_modules",
      "package.json"
    ],
    "mac": {
      "notarize": false,
      "target": {
        "target": "default",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "edjafarov",
      "repo": "kiagent-core",
      "releaseType": "draft"
    }
  },
  "collective": {
    "url": "https://opencollective.com/electron-react-boilerplate-594"
  },
  "overrides": {
    "node-abi": "^3.92.0",
    "electron-to-chromium": "^1.5.373"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=7.x",
      "onFail": "error"
    }
  },
  "electronmon": {
    "patterns": [
      "!**/**",
      "src/main/**",
      ".erb/dll/**"
    ],
    "logLevel": "quiet"
  }
}
